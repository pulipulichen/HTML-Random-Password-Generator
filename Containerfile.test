FROM mcr.microsoft.com/playwright:v1.40.0-jammy

WORKDIR /app

RUN npm install -g http-server

WORKDIR /deps
RUN npm init -y && npm install @playwright/test@1.40.0

WORKDIR /app

CMD ["sh", "-c", "created_link=0; if [ ! -e /app/node_modules ]; then ln -s /deps/node_modules /app/node_modules && created_link=1; fi; cleanup() { if [ \"$created_link\" -eq 1 ]; then rm -f /app/node_modules; fi; }; trap cleanup EXIT; http-server . -p 8080 & sleep 2 && /deps/node_modules/.bin/playwright test --output=/app/playwright-report-videos"]
